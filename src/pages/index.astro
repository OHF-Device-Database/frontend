---
import Layout from "../layouts/Layout.astro";
import { fetchDeviceCount } from "../lib/api";

const total = await fetchDeviceCount();
---

<Layout page="home">
    <div class="home-screen">
        <section class="hero">
            <div class="container hero-center">
                <h1>Find the right device for your smart home</h1>
                <p class="hero-lede">Real-world data from millions of Home Assistant installations</p>
                <div class="hero-search-wrap">
                    <device-search size="hero" placeholder="Search"></device-search>
                </div>
                <div class="hero-actions">
                    <a href="/browse">Browse all {total} devices →</a>
                </div>
            </div>
        </section>
    </div>
</Layout>
