---
import Layout from "../layouts/Layout.astro";
---

<Layout page="page" title="Sign in">
    <div class="ce-auth-page">
        <div class="ce-auth-card">
            <div class="ce-auth-head">
                <h1 class="ce-auth-title">Sign in</h1>
                <p class="ce-auth-sub">
                    Sign in to suggest edits and track your contributions. Reading the Device Database never requires an
                    account.
                </p>
            </div>
            <sign-in-form></sign-in-form>
        </div>
    </div>
</Layout>
