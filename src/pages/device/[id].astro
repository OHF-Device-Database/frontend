---
import haLogo from "../../assets/ha-logo.svg?raw";
import Layout from "../../layouts/Layout.astro";
import { fetchDevice, fetchDeviceCount } from "../../lib/api";
import { CACHE_POLICY, applyCdnCache } from "../../lib/cache";
import { CATEGORY_LABEL } from "../../lib/categories";
import { connectivityDisplay, internetStatus, type VersionInfo } from "../../lib/device";
import { categoryGlyph, icon } from "../../lib/icons";

export const prerender = false;

const { id } = Astro.params;
const device = id ? await fetchDevice(id) : undefined;

if (device) {
    // Device pages change rarely: cache hard at the origin and the CDN edge (fresh 5min,
    // stale-while-revalidate 1h).
    Astro.cache.set({ maxAge: CACHE_POLICY.device.maxAge, swr: CACHE_POLICY.device.swr, tags: ["devices"] });
    applyCdnCache(Astro.response.headers, CACHE_POLICY.device);
} else {
    Astro.response.status = 404;
    applyCdnCache(Astro.response.headers, CACHE_POLICY.deviceMissing);
}

const fmtDate = (iso: string): string | null =>
    iso ? new Date(iso).toLocaleDateString("en-US", { day: "numeric", month: "short", year: "numeric" }) : null;

const view = device
    ? (() => {
          const status = internetStatus(device);
          const verdict =
              status === "local"
                  ? { text: "Works without the cloud", color: "var(--success)" }
                  : status === "requires"
                    ? { text: "Requires the manufacturer’s cloud", color: "var(--neutral-400)" }
                    : { text: "Connectivity data not yet available", color: "var(--neutral-400)" };
          const body =
              status === "requires"
                  ? "This device requires an active internet connection to function. Setup, day-to-day control, or both rely on a manufacturer service. If the manufacturer's servers go offline or the product is discontinued, the device may stop working."
                  : status === "local"
                    ? "This device works fully on your local network. It does not need an internet connection or a manufacturer account to be set up or controlled. If your internet goes down, the device keeps working."
                    : "We don't yet have connectivity data for this device, so we can't say whether it depends on the manufacturer's cloud. This page will update as more reports come in.";
          return {
              category: CATEGORY_LABEL[device.category] ?? device.category,
              connectivity: connectivityDisplay(device),
              status,
              verdict,
              body,
              lastVerified: fmtDate(device.lastVerified),
              firstSeen: fmtDate(device.firstSeen),
          };
      })()
    : null;

const total = await fetchDeviceCount();

// Version histories can be long; show the most recent few, newest last (the
// current version), and summarize the rest.
const MAX_VERSIONS = 10;

const versionInfos = (info: VersionInfo[], strings: string[]): VersionInfo[] =>
    info.length > 0 ? info : strings.map((version) => ({ version, firstEncountered: "" }));
const recentVersions = (all: VersionInfo[]): { hidden: number; shown: VersionInfo[] } => ({
    hidden: Math.max(0, all.length - MAX_VERSIONS),
    shown: all.slice(-MAX_VERSIONS),
});
const software = device
    ? recentVersions(versionInfos(device.softwareVersionInfo, device.softwareVersions))
    : { hidden: 0, shown: [] };
const hardware = device
    ? recentVersions(versionInfos(device.hardwareVersionInfo, device.hardwareVersions))
    : { hidden: 0, shown: [] };

const versionMeta = (entry: VersionInfo): string => {
    const seen = fmtDate(entry.firstEncountered);
    return [
        seen ? `First seen ${seen}` : "",
        entry.active && entry.active > 0 ? `${entry.active.toLocaleString("en-US")} active installs` : "",
    ]
        .filter(Boolean)
        .join(" · ");
};
const toVersionEntries = (entries: VersionInfo[]) =>
    [...entries].reverse().map((entry, i) => ({
        version: entry.version,
        current: i === 0,
        meta: versionMeta(entry),
    }));
const softwareEntries = toVersionEntries(software.shown);
const hardwareEntries = toVersionEntries(hardware.shown);
const currentSoftware = software.shown.at(-1)?.version ?? "";
const currentHardware = hardware.shown.at(-1)?.version ?? "";

const haDocsUrl = device?.haIntegrationDomain
    ? `https://www.home-assistant.io/integrations/${device.haIntegrationDomain}`
    : null;
---

{
    device && view ? (
        <Layout page="detail" back="/browse" title={`${device.manufacturer} ${device.name}`}>
            <div class="container detail-wrap">
                <nav class="breadcrumb" aria-label="Breadcrumb">
                    <a href="/browse">Devices</a>
                    <span class="sep">›</span>
                    <a href={`/browse?category=${device.category}`}>{view.category}</a>
                </nav>

                <header class="detail-head">
                    <div class="detail-image" set:html={categoryGlyph(device.category, 72)} />
                    <div class="detail-title">
                        <h1>{device.name}</h1>
                        <div class="detail-manu">
                            by{" "}
                            <a href={`/browse?manufacturer=${encodeURIComponent(device.manufacturer)}`}>
                                {device.manufacturer}
                            </a>
                        </div>
                        <div class="glance">
                            <span class="glance-key">Connectivity</span>
                            <span class={"local-indicator " + view.connectivity.cls}>
                                <span class="dot" />
                                {view.connectivity.label}
                            </span>
                            <span class="glance-key">Integration</span>
                            <span>{device.haIntegration || "-"}</span>
                        </div>
                    </div>
                </header>

                <div class="detail-body">
                    <section class="detail-verdict">
                        <figure class="detail-figure">
                            <div class="detail-figure-frame">
                                <div class="verdict verdict-flush">
                                    <span class="verdict-dot" style={`background:${view.verdict.color}`} />
                                    <span class="verdict-text">{view.verdict.text}</span>
                                </div>
                                <p class="verdict-body">{view.body}</p>
                            </div>
                        </figure>
                    </section>

                    <main class="article">
                        <section class="article-section ha-connect">
                            <span class="ha-connect-logo" aria-hidden="true" set:html={haLogo} />
                            <h2>Connects with Home Assistant</h2>
                            {device.haIntegration ? (
                                <>
                                    <p>
                                        Add the matching integration from Settings, Devices and services, Add
                                        integration. Follow the on-screen steps to connect this device.
                                    </p>
                                    <dl class="ha-meta">
                                        <dt>Integration</dt>
                                        <dd>{device.haIntegration}</dd>
                                        {device.entityTypes.length > 0 && (
                                            <>
                                                <dt>Supported entities</dt>
                                                <dd class="ha-entity-chips">
                                                    {device.entityTypes.map((et) => (
                                                        <span class="ha-entity-chip mono">{et}</span>
                                                    ))}
                                                </dd>
                                            </>
                                        )}
                                    </dl>
                                    {haDocsUrl && (
                                        <p class="ha-docs-link">
                                            <a href={haDocsUrl} target="_blank" rel="noopener">
                                                Read the Home Assistant documentation{" "}
                                                <span set:html={icon("open", 14)} />
                                            </a>
                                        </p>
                                    )}
                                </>
                            ) : (
                                <p class="muted">
                                    No Home Assistant integration is currently associated with this device.
                                </p>
                            )}
                        </section>

                        <section class="article-section">
                            <h2>Specifications</h2>
                            <div class="spec-accordions">
                                <details class="spec-acc" open>
                                    <summary class="spec-acc-summary">
                                        <span>Ecosystems</span>
                                        <span class="spec-acc-chevron" set:html={icon("chevronDown", 18)} />
                                    </summary>
                                    <div class="spec-acc-body">
                                        <dl class="spec-dl">
                                            <div class="trait-row">
                                                <dt>Connects with</dt>
                                                <dd>
                                                    <span class="ha-chip">
                                                        <span class="ha-chip-badge" aria-hidden="true" set:html={haLogo} />
                                                        Home Assistant
                                                    </span>
                                                </dd>
                                            </div>
                                        </dl>
                                    </div>
                                </details>

                                {software.shown.length > 0 && (
                                    <details class="spec-acc" open>
                                        <summary class="spec-acc-summary">
                                            <span>Software version</span>
                                            <span class="spec-acc-chevron" set:html={icon("chevronDown", 18)} />
                                        </summary>
                                        <div class="spec-acc-body">
                                            <dl class="spec-dl">
                                                <div class="trait-row">
                                                    <dt>Current</dt>
                                                    <dd class="spec-version-dd">
                                                        <span class="mono">{currentSoftware}</span>
                                                        {software.shown.length > 1 && (
                                                            <version-history entries={JSON.stringify(softwareEntries)}></version-history>
                                                        )}
                                                    </dd>
                                                </div>
                                            </dl>
                                        </div>
                                    </details>
                                )}

                                {hardware.shown.length > 0 && (
                                    <details class="spec-acc" open>
                                        <summary class="spec-acc-summary">
                                            <span>Hardware version</span>
                                            <span class="spec-acc-chevron" set:html={icon("chevronDown", 18)} />
                                        </summary>
                                        <div class="spec-acc-body">
                                            <dl class="spec-dl">
                                                <div class="trait-row">
                                                    <dt>Current</dt>
                                                    <dd class="spec-version-dd">
                                                        <span class="mono">{currentHardware}</span>
                                                        {hardware.shown.length > 1 && (
                                                            <version-history entries={JSON.stringify(hardwareEntries)}></version-history>
                                                        )}
                                                    </dd>
                                                </div>
                                            </dl>
                                        </div>
                                    </details>
                                )}

                                <details class="spec-acc" open>
                                    <summary class="spec-acc-summary">
                                        <span>Product identifiers</span>
                                        <span class="spec-acc-chevron" set:html={icon("chevronDown", 18)} />
                                    </summary>
                                    <div class="spec-acc-body">
                                        <dl class="spec-dl">
                                            <div class="trait-row">
                                                <dt>Model number</dt>
                                                <dd>
                                                    <span class="spec-chip mono">{device.model}</span>
                                                </dd>
                                            </div>
                                        </dl>
                                    </div>
                                </details>
                            </div>
                        </section>
                    </main>

                    <aside>
                        <div class="aside-card aside-stats">
                            <h4>Real-world data</h4>
                            <dl class="aside-stat-list">
                                <div class="aside-stat">
                                    <dt>Reports</dt>
                                    <dd>{device.reports.toLocaleString("en-US")}</dd>
                                </div>
                                <div class="aside-stat">
                                    <dt>Installations</dt>
                                    <dd>{device.installs.toLocaleString("en-US")}</dd>
                                </div>
                                <div class="aside-stat">
                                    <dt>Last verified</dt>
                                    <dd>{view.lastVerified ?? "-"}</dd>
                                </div>
                                {view.firstSeen && (
                                    <div class="aside-stat">
                                        <dt>First seen</dt>
                                        <dd>{view.firstSeen}</dd>
                                    </div>
                                )}
                            </dl>
                            <p class="aside-stats-note">
                                Anonymized telemetry from opt-in Home Assistant users. No accounts, no personal
                                data, no tracking.
                            </p>
                            <p class="aside-source-linkrow">
                                <a href="/how-it-works">
                                    Learn about the methodology <span set:html={icon("open", 12)} />
                                </a>
                            </p>
                        </div>
                    </aside>
                </div>
            </div>
        </Layout>
    ) : (
        <Layout page="page" title="Not found">
            <div class="container" style="padding: 80px 0; text-align: center;">
                <div class="eyebrow" style="margin-bottom: 12px;">
                    404
                </div>
                <h1 style="margin-bottom: 16px;">Device not found.</h1>
                <a class="btn btn-primary" href="/browse">
                    Browse all {total} devices
                </a>
            </div>
        </Layout>
    )
}
