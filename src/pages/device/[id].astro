---
import Layout from "../../layouts/Layout.astro";
import { fetchDevice, fetchDevices } from "../../lib/api";
import { requiresInternet } from "../../lib/device";
import { CATEGORY_LABEL } from "../../lib/categories";
import { categoryGlyph } from "../../lib/icons";

export const prerender = false;

const { id } = Astro.params;
const device = id ? await fetchDevice(id) : undefined;

if (!device) {
    Astro.response.status = 404;
}

const needsInternet = device ? requiresInternet(device) : false;
const total = (await fetchDevices()).length;
---

{
    device ? (
        <Layout page="detail" back="/browse" title={`${device.manufacturer} ${device.name}`}>
            <div class="detail container">
                <div class="detail-header">
                    <div class="detail-thumb" set:html={categoryGlyph(device.category, 56)} />
                    <div class="detail-info">
                        <div class="device-category">{CATEGORY_LABEL[device.category]}</div>
                        <h1>{device.name}</h1>
                        <div class="detail-model">
                            {device.manufacturer} · {device.model}
                        </div>
                        <div class="device-badges">
                            <span class={"local-indicator " + (needsInternet ? "net-yes" : "net-no")}>
                                <span class="dot" />
                                {needsInternet ? "Requires internet" : "Local connection"}
                            </span>
                        </div>
                    </div>
                </div>
                <p class="detail-summary">{device.summary}</p>
                <div class="detail-stats">
                    <span>
                        Reports <b>{device.reports.toLocaleString("en-US")}</b>
                    </span>
                    <span>
                        Installations <b>{device.installs.toLocaleString("en-US")}</b>
                    </span>
                </div>
            </div>
        </Layout>
    ) : (
        <Layout page="page" title="Not found">
            <div class="container" style="padding: 80px 0; text-align: center;">
                <div class="eyebrow" style="margin-bottom: 12px;">404</div>
                <h1 style="margin-bottom: 16px;">Device not found.</h1>
                <a class="btn btn-primary" href="/browse">
                    Browse all {total} devices
                </a>
            </div>
        </Layout>
    )
}
