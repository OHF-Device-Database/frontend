---
import DeviceCard from "../components/DeviceCard.astro";
import Layout from "../layouts/Layout.astro";
import { fetchDeviceResults, fetchManufacturers } from "../lib/api";
import { parseBrowseFilters } from "../lib/browse-filters";
import { CACHE_POLICY, applyCdnCache } from "../lib/cache";
import { icon } from "../lib/icons";

export const prerender = false;

// Cache the rendered HTML per filter+page URL, both in the origin memoryCache (Astro.cache)
// and at the CDN edge (Cloudflare) via the response headers — serve fresh briefly, then
// serve stale while revalidating in the background.
Astro.cache.set({ maxAge: CACHE_POLICY.browse.maxAge, swr: CACHE_POLICY.browse.swr, tags: ["devices"] });
applyCdnCache(Astro.response.headers, CACHE_POLICY.browse);

const filters = parseBrowseFilters(Astro.url.searchParams);
const pageParam = Number(Astro.url.searchParams.get("page") ?? "0");
const page = Number.isFinite(pageParam) && pageParam > 0 ? Math.floor(pageParam) : 0;

const [results, manufacturers] = await Promise.all([
    fetchDeviceResults(filters, page),
    fetchManufacturers(),
]);
const manufacturersJson = JSON.stringify(manufacturers);

const pageHref = (p: number): string => {
    const params = new URLSearchParams(Astro.url.searchParams);
    if (p <= 0) params.delete("page");
    else params.set("page", String(p));
    const qs = params.toString();
    return qs ? `/browse?${qs}` : "/browse";
};

const hasPrev = results.page > 0;
const hasNext = results.page < results.pageCount - 1;

type PageItem = { gap: true } | { gap: false; page: number };
const paginationItems = (current: number, count: number): PageItem[] => {
    const wanted = new Set<number>();
    for (const p of [0, count - 1, current - 1, current, current + 1]) {
        if (p >= 0 && p < count) wanted.add(p);
    }
    const ordered = [...wanted].sort((a, b) => a - b);
    const items: PageItem[] = [];
    let prev = -1;
    for (const p of ordered) {
        if (p - prev > 1) items.push({ gap: true });
        items.push({ gap: false, page: p });
        prev = p;
    }
    return items;
};
const pages = results.pageCount > 1 ? paginationItems(results.page, results.pageCount) : [];
---

<Layout page="browse" title="Browse">
    <div class="browse">
        <browse-filters-sheet manufacturers={manufacturersJson}></browse-filters-sheet>
        <div class="container browse-grid">
            <browse-toolbar matchCount={results.total}></browse-toolbar>
            <device-filters manufacturers={manufacturersJson}></device-filters>
            <div class="browse-main">
                {
                    results.devices.length === 0 ? (
                        <p class="browse-empty">No devices match these filters.</p>
                    ) : (
                        <>
                            <div class="device-list">
                                {results.devices.map((device) => (
                                    <DeviceCard device={device} />
                                ))}
                            </div>
                            {pages.length > 0 && (
                                <nav class="browse-pagination" aria-label="Pagination">
                                    {hasPrev ? (
                                        <a class="browse-pagination-step" href={pageHref(results.page - 1)} rel="prev">
                                            <span set:html={icon("chevronL", 16)} />
                                            <span>Previous</span>
                                        </a>
                                    ) : (
                                        <span class="browse-pagination-step is-disabled" aria-disabled="true">
                                            <span set:html={icon("chevronL", 16)} />
                                            <span>Previous</span>
                                        </span>
                                    )}
                                    <span class="browse-pagination-pages">
                                        {pages.map((item) =>
                                            item.gap ? (
                                                <span class="browse-pagination-gap" aria-hidden="true">
                                                    …
                                                </span>
                                            ) : item.page === results.page ? (
                                                <span
                                                    class="browse-pagination-page is-current"
                                                    aria-current="page"
                                                >
                                                    {(item.page + 1).toLocaleString()}
                                                </span>
                                            ) : (
                                                <a
                                                    class="browse-pagination-page"
                                                    href={pageHref(item.page)}
                                                    aria-label={`Page ${item.page + 1}`}
                                                >
                                                    {(item.page + 1).toLocaleString()}
                                                </a>
                                            ),
                                        )}
                                    </span>
                                    {hasNext ? (
                                        <a class="browse-pagination-step" href={pageHref(results.page + 1)} rel="next">
                                            <span>Next</span>
                                            <span set:html={icon("chevronR", 16)} />
                                        </a>
                                    ) : (
                                        <span class="browse-pagination-step is-disabled" aria-disabled="true">
                                            <span>Next</span>
                                            <span set:html={icon("chevronR", 16)} />
                                        </span>
                                    )}
                                </nav>
                            )}
                        </>
                    )
                }
            </div>
        </div>
    </div>
</Layout>
