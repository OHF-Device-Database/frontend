---
import { icon } from "../lib/icons";
import { LOGO_SVG } from "../lib/logo";
import SearchBox from "./SearchBox.astro";

interface Props {
    page: string;
    back?: string;
}

const { page, back } = Astro.props;
const showSearch = page !== "home";
---

<header class="appnav" data-appnav>
    <div class="container appnav-inner">
        <div class="appnav-left">
            {
                back && (
                    <a href={back} class="appnav-back" aria-label="Back to devices" set:html={icon("arrowL", 18)} />
                )
            }
            <brand-menu>
                <a
                    href="/"
                    class="brand"
                    aria-label="Device Database, home"
                    style="margin-top: 4px;"
                    set:html={LOGO_SVG}
                />
            </brand-menu>
        </div>
        {showSearch ? <SearchBox size="header" /> : <div></div>}
        <community-auth class="appnav-right"></community-auth>
    </div>
</header>

<script>
    const sync = () => {
        const nav = document.querySelector("[data-appnav]");
        if (nav) nav.classList.toggle("is-scrolled", window.scrollY > 0);
    };

    let bound = false;
    const bind = () => {
        if (bound) return;
        bound = true;
        sync();
        window.addEventListener("scroll", sync, { passive: true });
    };

    document.addEventListener("astro:page-load", bind);
</script>
