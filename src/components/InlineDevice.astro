---
import { type PolyDevice as _Device } from "../types/device";

interface Props {
    self: _Device;
}

const { self } = Astro.props;
---

<style>
    .self {
        display: flex;
        flex-direction: row;
        align-items: center;
        gap: 12px;
        width: 100%;
        padding: 8px;
        box-sizing: border-box;
        background-color: #f5f5f5;
        border-radius: 8px;
        color: black;
        transition: background-color 0.15s ease;
    }

    .self:hover {
        background-color: #e8e8e8;
    }

    .self-image {
        width: 64px;
        height: 64px;
        border-radius: 8px;
        background-color: #e0e0e0;
        flex-shrink: 0;
    }

    .self-info {
        display: flex;
        gap: 4px;
        flex-direction: column;
        flex: 1;
        min-width: 0;
    }

    .self-info > div {
        overflow: hidden;
        white-space: nowrap;
        text-overflow: ellipsis;
    }

    .model {
        font-weight: 700;
    }

    .model-id {
        font-family: monospace;
    }

    .count {
        margin-left: auto;
        font-variant-numeric: tabular-nums;
        text-decoration: none;
        background-color: black;
        color: white;
        border-radius: 999px;
        padding: 2px 8px;
        font-size: 0.8em;
        font-weight: 500;
    }
</style>

<div class="self">
    <div class="self-image"></div>
    <div class="self-info">
        <div class="integration">{self.integration}</div>
        <div class="manufacturer">{self.manufacturer}</div>
        <div>
            {
                typeof self.model !== "undefined" ? (
                    <Fragment>
                        <span class="model">{self.model}</span>
                        {typeof self.model_id !== "undefined" ? (
                            <code class="model-id">{self.model_id}</code>
                        ) : (
                            <Fragment />
                        )}
                    </Fragment>
                ) : (
                    <code class="model-id">{self.model_id}</code>
                )
            }
        </div>
    </div>
    <div class="count">{self.count}</div>
</div>
